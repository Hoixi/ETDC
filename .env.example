# ============================================================
# Hoixi Bot + Panel — ortam değişkenleri
# Bu dosyayı .env olarak kopyala ve doldur. .env'i ASLA commit'leme.
#   cp .env.example .env
# ============================================================

# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://panel.enterthedarkcarnival.com/api/auth/callback/discord
# dev'de hızlı slash command register için (boş bırakılırsa global register edilir)
GUILD_ID=

# --- Veritabanı (PostgreSQL) ---
# Local geliştirme için. Docker'da compose bu değeri "postgres" host'uyla override eder.
DATABASE_URL=postgresql://hoixi:hoixi@localhost:5432/hoixi?schema=public
# Docker'da postgres şifresi (compose kullanır). Local'de gerekmez.
POSTGRES_PASSWORD=hoixi

# --- Lavalink (müzik — Milestone 9) ---
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
# Spotify metadata (LavaSrc plugin) — ses yine YouTube'dan çekilir
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Bot iç API <-> Panel ---
INTERNAL_API_KEY=
BOT_API_URL=http://bot:3001

# --- Panel (Next.js / Auth.js) ---
NEXTAUTH_URL=https://panel.enterthedarkcarnival.com
SESSION_SECRET=

# --- Kick yayın bildirimi (sonraki sürüm — şimdilik kapalı) ---
# KICK_CHANNEL=

NODE_ENV=development
