// Hoixi — Prisma şeması.
// Spec bölüm 4'teki taslağı temel alır. Bot ve panel aynı DB'ye bağlanır.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id            String   @id // discord guild id
  welcomeConfig Json? // {channelId, bg, title, subtitle, enabled}
  goodbyeConfig Json? // {channelId, title, subtitle, enabled}
  levelConfig   Json? // {xpPerMsg, cooldownSec, levelUpChannelId, cardStyle, voiceXpEnabled, voiceXpPerMin}
  musicConfig   Json? // {djRoleId, defaultVolume, maxQueue}
  logConfig     Json? // {joinLeave, modLog, messageLog} -> channelId'ler
  streamConfig  Json? // {enabled, kickChannel, discordChannelId, pingRoleId, pollSec}
  arenaConfig   Json? // {enabled, grindMinutes, dropsPerSession}
  createdAt     DateTime @default(now())

  rolePanels  RolePanel[]
  members     MemberXP[]
  levelRewards LevelReward[]
  warnings    Warning[]
  arenaPlayers ArenaPlayer[]
}

model RolePanel {
  id        String        @id @default(cuid())
  guildId   String
  guild     Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  messageId String? // yayınlanınca dolar
  embed     Json // {title, description, color, image, thumbnail, footer}
  mode      RolePanelMode @default(TOGGLE) // TOGGLE | UNIQUE | VERIFY | ADD_ONLY
  buttons   RoleButton[]
  createdBy String
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())

  @@index([guildId])
}

model RoleButton {
  id      String      @id @default(cuid())
  panelId String
  panel   RolePanel   @relation(fields: [panelId], references: [id], onDelete: Cascade)
  roleId  String
  label   String
  emoji   String?
  style   ButtonStyle @default(SECONDARY) // PRIMARY | SECONDARY | SUCCESS | DANGER
  order   Int

  @@index([panelId])
}

model MemberXP {
  guildId   String
  userId    String
  xp        Int       @default(0)
  level     Int       @default(0)
  lastMsgAt DateTime?
  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
}

// Level -> ödül rolü eşleşmesi (panelden tanımlanır, bot otomatik verir)
model LevelReward {
  id      String @id @default(cuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  level   Int
  roleId  String

  @@unique([guildId, level])
  @@index([guildId])
}

// Moderasyon uyarıları
model Warning {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  moderator String
  reason    String
  createdAt DateTime @default(now())

  @@index([guildId, userId])
}

enum RolePanelMode {
  TOGGLE
  UNIQUE
  VERIFY
  ADD_ONLY
}

enum ButtonStyle {
  PRIMARY
  SECONDARY
  SUCCESS
  DANGER
}

// ============================================================
// Karnaval Arenası (features/arena) — idle loot grinder + PvP/PvE
// ============================================================

model ArenaPlayer {
  guildId        String
  userId         String
  level          Int       @default(1)
  xp             Int       @default(0)
  tokens         Int       @default(0) // Jeton
  elo            Int       @default(1000)
  wins           Int       @default(0)
  losses         Int       @default(0)
  stage          Int       @default(1) // /kas aşaması — boss yenilince ilerler, iLvl bunu takip eder
  skills         Json      @default("{}") // pasif skill tree: { nodeId: rank }
  abilities      Json      @default("{}") // aktif yetenekler: { owned, equipped, addonsOwned, attached }
  // Idle kasma oturumu (tek aktif oturum)
  grindEndsAt    DateTime? // null = oturum yok
  grindCollected Boolean   @default(true)
  lastDuelAt     DateTime?
  createdAt      DateTime  @default(now())

  guild Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  items ArenaItem[]

  @@id([guildId, userId])
}

model ArenaItem {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  baseType  String // şablon ("Paslı Bıçak" vb.)
  name      String
  rarity    Rarity
  slot      ItemSlot
  iLvl      Int
  // Birincil statlar
  atk       Int      @default(0)
  def       Int      @default(0)
  hp        Int      @default(0)
  spd       Int      @default(0)
  luck      Int      @default(0)
  // İkincil/özel statlar (affix): [{type, value}] + Legendary pasifi
  affixes   Json     @default("[]")
  passive   String? // Legendary benzersiz pasif adı
  upgrade   Int      @default(0) // +0..+10 yükseltme
  equipped  Boolean  @default(false)
  createdAt DateTime @default(now())

  player ArenaPlayer @relation(fields: [guildId, userId], references: [guildId, userId], onDelete: Cascade)

  @@index([guildId, userId])
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemSlot {
  // Ana ekipman (6)
  WEAPON // Silah
  OFFHAND // Alt silah
  HELMET // Kask
  ARMOR // Zırh
  GLOVES // Eldiven
  BOOTS // Ayakkabı
  // Takı (4 giyme slotu: RING iki kez giyilebilir → Yüzük 1 + Yüzük 2)
  NECKLACE // Kolye
  RING // Yüzük
  EARRING // Küpe
  // --- Eski slotlar ---
  // remap-slots.sql ile HEAD→HELMET, BODY→ARMOR, ACCESSORY→NECKLACE'e taşınır.
  // Enum'dan SİLİNMEDİ: db push'un yıkıcı enum yeniden-oluşturmasını (data-loss) tetiklememesi için.
  HEAD
  BODY
  ACCESSORY
}
